<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <!-- Header with Solid Red -->
        <View
            android:id="@+id/view_header"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="#FF1100"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Profile Picture -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_profile_pic"
            android:layout_width="130dp"
            android:layout_height="130dp"
            android:layout_marginTop="130dp"
            android:src="@android:drawable/sym_def_app_icon"
            android:scaleType="centerCrop"
            android:padding="4dp"
            android:background="@android:color/white"
            app:shapeAppearanceOverlay="@style/CircleImage"
            app:strokeWidth="2dp"
            app:strokeColor="@android:color/white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:elevation="8dp"/>

        <!-- Camera FAB -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btn_change_image"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@android:drawable/ic_menu_camera"
            app:fabSize="mini"
            app:backgroundTint="#FF1100"
            app:tint="@android:color/white"
            app:layout_constraintBottom_toBottomOf="@id/iv_profile_pic"
            app:layout_constraintEnd_toEndOf="@id/iv_profile_pic"
            android:layout_marginBottom="4dp"
            android:layout_marginEnd="4dp"
            android:elevation="12dp"
            android:contentDescription="Change Profile Picture" />

        <!-- Personal Information Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_personal_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@android:color/white"
            app:layout_constraintTop_toBottomOf="@id/iv_profile_pic">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Personal Details"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="#1E232C"
                    android:layout_marginBottom="16dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:hint="Email Address"
                    app:startIconDrawable="@android:drawable/ic_dialog_email"
                    android:layout_marginBottom="12dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/tv_email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:focusable="false"
                        android:clickable="false"
                        android:cursorVisible="false"
                        android:textColor="#757575" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:hint="Display Name"
                    app:startIconDrawable="@android:drawable/ic_menu_myplaces"
                    android:layout_marginBottom="12dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_bio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:hint="Bio"
                    app:startIconDrawable="@android:drawable/ic_menu_info_details">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_bio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine"
                        android:minLines="2"
                        android:gravity="top" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Certifications Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_certificate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@android:color/white"
            app:layout_constraintTop_toBottomOf="@id/card_personal_info">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tv_certificate_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Certifications"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="#1E232C"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/tv_cert_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Helped more than 10 incidents"
                    android:textSize="14sp"
                    android:padding="12dp"
                    android:background="@drawable/selectable_cert"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tv_cert_2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Have knowledge in First Aid"
                    android:textSize="14sp"
                    android:padding="12dp"
                    android:background="@drawable/selectable_cert"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tv_cert_3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Posted more than 10 incidents"
                    android:textSize="14sp"
                    android:padding="12dp"
                    android:background="@drawable/selectable_cert"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Badges Section -->
        <LinearLayout
            android:id="@+id/ll_badges"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/card_certificate"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
        </LinearLayout>

        <!-- Save Button -->
        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="32dp"
            android:text="Save Changes"
            android:textStyle="bold"
            android:backgroundTint="#FF1100"
            android:textColor="#FFFFFF"
            android:letterSpacing="0.05"
            app:cornerRadius="8dp"
            app:layout_constraintTop_toBottomOf="@id/ll_badges" />

        <!-- Logout Button -->
        <Button
            android:id="@+id/btn_logout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Log Out"
            android:textColor="#D32F2F"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            app:layout_constraintTop_toBottomOf="@id/btn_save"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
