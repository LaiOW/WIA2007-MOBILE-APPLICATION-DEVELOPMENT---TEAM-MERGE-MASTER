<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Pressed state -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#BBDEFB"/> <!-- Light blue when pressed -->
            <corners android:radius="16dp"/>
        </shape>
    </item>

    <!-- Selected state -->
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="#90CAF9"/> <!-- Darker blue when selected -->
            <corners android:radius="16dp"/>
        </shape>
    </item>

    <!-- Default state -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#E0E0E0"/> <!-- Default gray -->
            <corners android:radius="16dp"/>
        </shape>
    </item>

</selector>
